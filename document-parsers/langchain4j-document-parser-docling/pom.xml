<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>dev.langchain4j</groupId>
        <artifactId>langchain4j-parent</artifactId>
        <version>1.15.0-beta25-SNAPSHOT</version>
        <relativePath>../../langchain4j-parent/pom.xml</relativePath>
    </parent>

    <artifactId>langchain4j-document-parser-docling</artifactId>
    <name>LangChain4j :: Document Parser :: Docling</name>

    <properties>
        <docling.version>0.5.1</docling.version>
        <!-- docling-serve-client brings in conflicting Jackson transitive versions -->
        <enforcer.skipRules>dependencyConvergence,requireUpperBoundDeps</enforcer.skipRules>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.testcontainers</groupId>
                <artifactId>testcontainers-bom</artifactId>
                <version>2.0.4</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <!-- LangChain4j Core -->
        <dependency>
            <groupId>dev.langchain4j</groupId>
            <artifactId>langchain4j-core</artifactId>
            <version>1.15.0-SNAPSHOT</version>
        </dependency>

        <!-- Docling Serve API -->
        <dependency>
            <groupId>ai.docling</groupId>
            <artifactId>docling-serve-api</artifactId>
            <version>${docling.version}</version>
        </dependency>

        <!-- Testing -->
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Docling reference client - optional; frameworks like Spring/Quarkus provide their own impl -->
        <dependency>
            <groupId>ai.docling</groupId>
            <artifactId>docling-serve-client</artifactId>
            <version>${docling.version}</version>
            <scope>runtime</scope>
            <optional>true</optional>
        </dependency>

        <!-- Docling Testcontainers for integration testing -->
        <dependency>
            <groupId>ai.docling</groupId>
            <artifactId>docling-testcontainers</artifactId>
            <version>${docling.version}</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>ch.qos.logback</groupId>
            <artifactId>logback-classic</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>
